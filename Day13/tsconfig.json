{
  "compilerOptions": {
    /* Language */
    "target": "ES2022",
    "lib": ["ES2022"],

    /* Module */
    "module": "CommonJS",
    "moduleResolution": "Node",
    "ignoreDeprecations": "6.0",

    /* Directories */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Type Checking */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    /* Module Interop */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    /* Source Maps */
    "sourceMap": true,

    /* Decorators */
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    /* Consistency */
    "forceConsistentCasingInFileNames": true,

    /* Performance */
    "skipLibCheck": true,

    /* Types */
    "types": ["node"],

    /* Incremental Build */
    "incremental": true
  },

  "include": [
    "src/**/*.ts",
    "prisma/**/*.ts"

  ],

  "exclude": [
    "node_modules",
    "dist",
    "prisma"
  ]
}